# ── SERVER ────────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=3000
KELAN_HTTP_PORT=3000
KELAN_HOST=0.0.0.0
KELAN_BIND_HOST=0.0.0.0
KELAN_DEBUG=false
KELAN_SERVER_URL=http://localhost:3000

# ── OLLAMA / AI ───────────────────────────────────────────────────────────────
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=gemma3:latest
OLLAMA_TIMEOUT_SECS=60
OLLAMA_TEMPERATURE=0.1
OLLAMA_MAX_TOKENS=300

# ── DATABASE ──────────────────────────────────────────────────────────────────
# Use SQLite for local development or PostgreSQL for production
DATABASE_URL=sqlite+aiosqlite:///data/kelan.db

# ── SECURITY ──────────────────────────────────────────────────────────────────
# Secret keys for sessions and tokens (minimum 32 characters suggested)
JWT_SECRET=your-jwt-secret-here-change-this
KELAN_JWT_SECRET=your-kelan-jwt-secret-here-change-this
REQUIRE_PQ=true

# ── EBPF / XDP / RATE LIMITS ──────────────────────────────────────────────────
KELAN_EBPF_ENABLED=true
KELAN_XDP_IFACE=eth0
XDP_INTERFACE=eth0
SYN_RATE_LIMIT=50
UDP_RATE_LIMIT=200

# ── CIRCUIT BREAKER ───────────────────────────────────────────────────────────
CB_FAILURE_THRESHOLD=3
CB_RECOVERY_TIMEOUT=30

# ── AGENTIC SYNC ──────────────────────────────────────────────────────────────
AGENTIC_ENABLED=true
AGENT_SYNC_ENDPOINT=/ws/agent
AGENT_AUTH_TOKEN=your-agent-auth-token-here

# ── MONITORING ────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=your-secure-grafana-password-here

# ── ALERTS ────────────────────────────────────────────────────────────────────
ALERT_EMAIL=your@email.com
ALERT_EMAIL_PASSWORD=your-gmail-app-password-here
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
